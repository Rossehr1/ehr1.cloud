# Block direct web access to includes/ if Apache allows (depends on Hostinger vhost).
# Optional: enable HTTPS redirect once SSL is active for ehr1.cloud.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^includes/ - [F,L]
  RewriteRule ^tools/ - [F,L]
  RewriteRule ^sql/ - [F,L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
</IfModule>
