# Copy this file to deploy/.env.deploy (same folder as deploy-paths.json).
# deploy/.env.deploy is gitignored — keep your real paths here only on your PC.
#
# New VPS from Git: edit deploy/deploy-paths.json (or copy from deploy-paths.example.json if you have no JSON yet),
#   then from deploy/:  powershell -ExecutionPolicy Bypass -File .\Prepare-NewVpsDeploy.ps1
#
# Optional: generate key and install to VPS authorized_keys (from deploy folder):
#   powershell -ExecutionPolicy Bypass -File .\Install-Ehr1SshKey.ps1 -NoPassphrase
#
# Private SSH key path (optional if you use the default %USERPROFILE%\.ssh\ehr1_vps_ed25519)
# EHR1_DEPLOY_SSH_IDENTITY_FILE=C:\Users\YourName\.ssh\ehr1_vps_ed25519
#
# Optional: override deploy-paths.json for SSH only (RemotePublicHtml / RemoteAppDir still come from JSON)
# EHR1_DEPLOY_SSH_HOST=177.7.52.88
# EHR1_DEPLOY_SSH_PORT=22
# EHR1_DEPLOY_SSH_USER=root
#
# Alternate file: set User environment variable EHR1_DEPLOY_ENV_FILE to a full path to another env file.
#
# Key passphrases: use ssh-agent (ssh-add). Do not store passphrases in this file.
