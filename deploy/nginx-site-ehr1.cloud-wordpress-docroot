# Install on VPS as:  /etc/nginx/sites-available/ehr1.cloud
#
#   sudo cp nginx-site-ehr1.cloud-wordpress-docroot /etc/nginx/sites-available/ehr1.cloud
# Enable (Hostinger nginx uses include sites-enabled/*.conf — symlink name must end in .conf):
#   sudo ln -sf /etc/nginx/sites-available/ehr1.cloud /etc/nginx/sites-enabled/ehr1.cloud.conf
#   sudo nginx -t && sudo systemctl reload nginx
#
# server_name and root match a typical Hostinger VPS WordPress tree. If your htdocs path
# differs, change only the root line after checking:  ls -la /home/user/htdocs/
#
# Only one nginx server block should use server_name ehr1.cloud. If you still have the
# older vhost pointing at /var/www/ehr1.cloud/public_html, remove that symlink from
# sites-enabled before enabling this one.
#
# WordPress multisite: if you need the extra rewrite/if rules from the panel 8080 vhost,
# copy them from /etc/nginx/sites-enabled/srv1632616.hstgr.cloud.conf into this file.
#
# HTTPS: see deploy/https-ehr1.cloud-steps.txt and deploy/nginx-ehr1.cloud-ssl-server.conf.example

server {
  listen 80;
  listen [::]:80;
  server_name ehr1.cloud www.ehr1.cloud;

  root /home/user/htdocs/srv1632616.hstgr.cloud;
  index index.php index.html;

  access_log /var/log/nginx/ehr1.cloud.access.log;
  error_log  /var/log/nginx/ehr1.cloud.error.log;

  include /etc/nginx/global_settings;

  location = /ehr1-data {
    return 301 /ehr1-data/;
  }

  location / {
    try_files $uri $uri/ /index.php?$args;
  }

  location ~ \.php$ {
    include fastcgi_params;
    fastcgi_intercept_errors on;
    fastcgi_index index.php;
    fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
    try_files $uri =404;
    fastcgi_read_timeout 3600;
    fastcgi_send_timeout 3600;
    fastcgi_param HTTPS "";
    fastcgi_param SERVER_PORT 80;
    fastcgi_pass 127.0.0.1:15001;
    fastcgi_param PHP_VALUE "error_log=/home/user/logs/php/error.log;
memory_limit=512M;
max_execution_time=60;
max_input_time=60;
max_input_vars=10000;
post_max_size=64M;
upload_max_filesize=64M;
auto_prepend_file=/home/user/.varnish-cache/controller.php;
date.timezone=UTC;
display_errors=off;";
  }

  location ~ /\.ht {
    deny all;
  }
}
